{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "#imports": ["./src/runtime/types/nuxt-shims.d.ts"],
      "#app": ["./src/runtime/types/nuxt-shims.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "tests/**/*.mjs"],
  "exclude": ["node_modules", "dist", ".nuxt", ".output"]
}
